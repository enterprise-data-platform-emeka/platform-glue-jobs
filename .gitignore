# Virtual environment
.venv/

# Deployment artifact — generated by `make deploy`, not committed
lib.zip

# Spark event logs — generated by local job runs, not committed
spark-events/

# Generated test data — not committed, regenerated with `make generate-bronze`
data/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
.coverage
htmlcov/
